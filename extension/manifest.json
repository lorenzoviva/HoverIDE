{
  "manifest_version": 3,
  "name": "HoverIDE",
  "version": "1.1",

  "permissions": ["storage", "scripting", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "images/png/HoverIDE_logo1.png",
      "32":  "images/png/HoverIDE_logo1.png",
      "48":  "images/png/HoverIDE_logo1.png",
      "128": "images/png/HoverIDE_logo1.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["iframe.html", "iframe.js", "style.css", "components/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16":  "images/png/HoverIDE_logo1.png",
    "32":  "images/png/HoverIDE_logo1.png",
    "48":  "images/png/HoverIDE_logo1.png",
    "128": "images/png/HoverIDE_logo1.png"
  }
}